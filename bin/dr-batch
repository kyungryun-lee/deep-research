#!/usr/bin/env bash
# Deep Research Batch API Integration
# Wraps Anthropic Message Batches API for 50% cost reduction on non-urgent research
# Handles batch creation, status polling, and result retrieval

set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/deep-research}"
BATCH_DIR="$DATA_DIR/batches"

usage() {
    cat <<'EOF'
Deep Research Batch API Integration

Usage: dr-batch <command> [args]

Commands:
  create --requests <json_path>   Submit batch of message requests
  status --batch-id <id>          Check batch processing status
  results --batch-id <id>         Retrieve batch results
  list [--last <n>]               List recent batches (default: 10)
  estimate --requests <json_path> Estimate cost savings vs real-time
  prepare-workers <plan_json>     Convert research plan to batch request format
  help                            Show this help

Pricing advantage: 50% discount on both input and output tokens
  opus   batch: $7.50/$37.50  (vs $15/$75 real-time)
  sonnet batch: $1.50/$7.50   (vs $3/$15 real-time)

Notes:
  - Batch results available within 24 hours (typically <1 hour)
  - Use for non-urgent research or bulk evaluations
  - Requires ANTHROPIC_API_KEY environment variable
  - Max 10,000 requests per batch, 100,000 messages total
EOF
}

check_api_key() {
    if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
        echo '{"error":"ANTHROPIC_API_KEY not set. Export it or add to ~/.bashrc","setup":"export ANTHROPIC_API_KEY=sk-ant-..."}' >&2
        return 1
    fi
}

cmd_create() {
    local requests_path=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --requests) requests_path="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$requests_path" ]] && { echo '{"error":"--requests required"}'; return 1; }
    [[ ! -f "$requests_path" ]] && { echo '{"error":"requests file not found: '"$requests_path"'"}'; return 1; }

    check_api_key || return 1
    mkdir -p "$BATCH_DIR" 2>/dev/null

    python3 - "$requests_path" "$BATCH_DIR" << 'PYEOF'
import json, sys, os
from datetime import datetime

try:
    import anthropic
except ImportError:
    print(json.dumps({"error": "anthropic package not installed. Run: pip install anthropic"}))
    sys.exit(1)

requests_path, batch_dir = sys.argv[1], sys.argv[2]

with open(requests_path) as f:
    requests_data = json.loads(f.read())

client = anthropic.Anthropic()

try:
    batch = client.messages.batches.create(requests=requests_data)

    record = {
        "batch_id": batch.id,
        "created_at": datetime.now().isoformat(),
        "request_count": len(requests_data),
        "status": batch.processing_status,
        "requests_file": requests_path
    }

    record_path = os.path.join(batch_dir, f"{batch.id}.json")
    with open(record_path, "w") as f:
        json.dump(record, f, ensure_ascii=False, indent=2)

    print(json.dumps({
        "batch_id": batch.id,
        "status": batch.processing_status,
        "request_count": len(requests_data),
        "message": "Batch submitted. Check status with: dr-batch status --batch-id " + batch.id
    }, ensure_ascii=False, indent=2))

except anthropic.APIError as e:
    print(json.dumps({"error": str(e)}))
    sys.exit(1)
PYEOF
}

cmd_status() {
    local batch_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --batch-id) batch_id="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$batch_id" ]] && { echo '{"error":"--batch-id required"}'; return 1; }
    check_api_key || return 1

    python3 - "$batch_id" "$BATCH_DIR" << 'PYEOF'
import json, sys, os

try:
    import anthropic
except ImportError:
    print(json.dumps({"error": "anthropic package not installed"}))
    sys.exit(1)

batch_id, batch_dir = sys.argv[1], sys.argv[2]

client = anthropic.Anthropic()
try:
    batch = client.messages.batches.retrieve(batch_id)

    result = {
        "batch_id": batch.id,
        "status": batch.processing_status,
        "request_counts": {
            "processing": batch.request_counts.processing,
            "succeeded": batch.request_counts.succeeded,
            "errored": batch.request_counts.errored,
            "canceled": batch.request_counts.canceled,
            "expired": batch.request_counts.expired
        }
    }

    if batch.processing_status == "ended":
        result["message"] = "Batch complete. Retrieve with: dr-batch results --batch-id " + batch.id

    # Update local record
    record_path = os.path.join(batch_dir, f"{batch_id}.json")
    if os.path.exists(record_path):
        with open(record_path) as f:
            record = json.load(f)
        record["status"] = batch.processing_status
        record["request_counts"] = result["request_counts"]
        with open(record_path, "w") as f:
            json.dump(record, f, ensure_ascii=False, indent=2)

    print(json.dumps(result, ensure_ascii=False, indent=2))

except anthropic.APIError as e:
    print(json.dumps({"error": str(e)}))
    sys.exit(1)
PYEOF
}

cmd_results() {
    local batch_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --batch-id) batch_id="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$batch_id" ]] && { echo '{"error":"--batch-id required"}'; return 1; }
    check_api_key || return 1

    python3 - "$batch_id" "$BATCH_DIR" << 'PYEOF'
import json, sys, os

try:
    import anthropic
except ImportError:
    print(json.dumps({"error": "anthropic package not installed"}))
    sys.exit(1)

batch_id, batch_dir = sys.argv[1], sys.argv[2]

client = anthropic.Anthropic()
try:
    results = []
    for result in client.messages.batches.results(batch_id):
        entry = {
            "custom_id": result.custom_id,
            "type": result.result.type if hasattr(result.result, 'type') else "unknown"
        }
        if hasattr(result.result, 'message'):
            msg = result.result.message
            content_text = ""
            for block in msg.content:
                if hasattr(block, 'text'):
                    content_text += block.text
            entry["content"] = content_text
            entry["input_tokens"] = msg.usage.input_tokens
            entry["output_tokens"] = msg.usage.output_tokens
            entry["model"] = msg.model
        elif hasattr(result.result, 'error'):
            entry["error"] = str(result.result.error)
        results.append(entry)

    # Save results locally
    results_path = os.path.join(batch_dir, f"{batch_id}-results.json")
    with open(results_path, "w") as f:
        json.dump(results, f, ensure_ascii=False, indent=2)

    total_input = sum(r.get("input_tokens", 0) for r in results)
    total_output = sum(r.get("output_tokens", 0) for r in results)

    print(json.dumps({
        "batch_id": batch_id,
        "total_results": len(results),
        "succeeded": sum(1 for r in results if "content" in r),
        "errored": sum(1 for r in results if "error" in r),
        "total_input_tokens": total_input,
        "total_output_tokens": total_output,
        "results_saved": results_path,
        "results": results
    }, ensure_ascii=False, indent=2))

except anthropic.APIError as e:
    print(json.dumps({"error": str(e)}))
    sys.exit(1)
PYEOF
}

cmd_list() {
    local last=10
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --last) last="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    mkdir -p "$BATCH_DIR" 2>/dev/null

    python3 - "$BATCH_DIR" "$last" << 'PYEOF'
import json, sys, os

batch_dir, limit = sys.argv[1], int(sys.argv[2])

batches = []
for f in sorted(os.listdir(batch_dir), reverse=True):
    if f.endswith('.json') and not f.endswith('-results.json'):
        with open(os.path.join(batch_dir, f)) as fh:
            try:
                batches.append(json.load(fh))
            except:
                pass

print(json.dumps({
    "total": len(batches),
    "showing": min(len(batches), limit),
    "batches": batches[:limit]
}, ensure_ascii=False, indent=2))
PYEOF
}

cmd_estimate() {
    local requests_path=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --requests) requests_path="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$requests_path" ]] && { echo '{"error":"--requests required"}'; return 1; }

    python3 - "$requests_path" << 'PYEOF'
import json, sys

PRICING = {
    "claude-opus-4-6":   {"rt_in": 15.0, "rt_out": 75.0, "batch_in": 7.5,  "batch_out": 37.5},
    "claude-sonnet-4-6": {"rt_in": 3.0,  "rt_out": 15.0, "batch_in": 1.5,  "batch_out": 7.5},
    "claude-haiku-4-5-20251001": {"rt_in": 1.0, "rt_out": 5.0, "batch_in": 0.5, "batch_out": 2.5},
}

# Shortname aliases
PRICING["opus"] = PRICING["claude-opus-4-6"]
PRICING["sonnet"] = PRICING["claude-sonnet-4-6"]
PRICING["haiku"] = PRICING["claude-haiku-4-5-20251001"]

with open(sys.argv[1]) as f:
    requests = json.loads(f.read())

total_rt = 0
total_batch = 0
estimates = []

for req in requests:
    model = req.get("params", {}).get("model", "claude-sonnet-4-6")
    max_tokens = req.get("params", {}).get("max_tokens", 4096)
    # Estimate input from message content length
    messages = req.get("params", {}).get("messages", [])
    est_input = sum(len(json.dumps(m)) // 4 for m in messages)  # rough char-to-token
    est_output = min(max_tokens, est_input)  # conservative estimate

    prices = PRICING.get(model, PRICING["sonnet"])
    rt_cost = est_input / 1e6 * prices["rt_in"] + est_output / 1e6 * prices["rt_out"]
    batch_cost = est_input / 1e6 * prices["batch_in"] + est_output / 1e6 * prices["batch_out"]
    total_rt += rt_cost
    total_batch += batch_cost

print(json.dumps({
    "request_count": len(requests),
    "realtime_cost_usd": round(total_rt, 4),
    "batch_cost_usd": round(total_batch, 4),
    "savings_usd": round(total_rt - total_batch, 4),
    "savings_pct": 50.0,
    "note": "Batch API provides flat 50% discount on all models"
}, ensure_ascii=False, indent=2))
PYEOF
}

cmd_prepare_workers() {
    local plan_json="${1:-}"
    [[ -z "$plan_json" ]] && { echo '{"error":"plan JSON path required"}'; return 1; }

    python3 - "$plan_json" << 'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    plan = json.loads(f.read())

workers = plan.get("workers", [])
requests = []

for i, worker in enumerate(workers):
    queries = worker.get("queries", [])
    focus = worker.get("focus_area", "general research")
    role = worker.get("role", f"worker-{i}")

    prompt = f"""당신의 역할: {role}
집중 영역: {focus}

아래 검색 쿼리를 실행하고 결과를 수집해주세요:
{chr(10).join('- ' + q for q in queries)}

소스 유형 우선순위: {worker.get('source_types', 'all')}
"""

    requests.append({
        "custom_id": f"worker-{i}-{role}",
        "params": {
            "model": "claude-sonnet-4-6",
            "max_tokens": 8192,
            "messages": [{"role": "user", "content": prompt}]
        }
    })

output_path = sys.argv[1].replace('.json', '-batch-requests.json')
with open(output_path, "w") as f:
    json.dump(requests, f, ensure_ascii=False, indent=2)

print(json.dumps({
    "workers": len(requests),
    "output": output_path,
    "message": f"Batch request file ready. Submit with: dr-batch create --requests {output_path}"
}, ensure_ascii=False, indent=2))
PYEOF
}

case "${1:-help}" in
    create)          shift; cmd_create "$@" ;;
    status)          shift; cmd_status "$@" ;;
    results)         shift; cmd_results "$@" ;;
    list)            shift; cmd_list "$@" ;;
    estimate)        shift; cmd_estimate "$@" ;;
    prepare-workers) shift; cmd_prepare_workers "$@" ;;
    help)            usage ;;
    *)               usage ;;
esac

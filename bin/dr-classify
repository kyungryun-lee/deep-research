#!/usr/bin/env bash
# Deep Research Query Classifier
# Deterministic rubric profile selection based on keyword patterns
# Replaces AI inference in Planner Step 1 (맥락 판단)

set -euo pipefail

usage() {
    cat <<'EOF'
Deep Research Query Classifier

Usage: dr-classify <command> [args]

Commands:
  profile "query"    Classify query → rubric profile (default/poc/exploration)
  complexity "query" Estimate query complexity (1/2/3) → worker count
  recency "query" [depth]  Determine recency window (1y/2y/5y)
  all "query" [depth]      Run all classifications at once
  help               Show this help
EOF
}

cmd_profile() {
    local query="$1"
    python3 - "$query" << 'PYEOF'
import json, sys, re

# Profile pattern dict — compiled once per invocation
PROFILE_PATTERNS = {
    "poc": [
        r'가능한가', r'될까', r'poc', r'테스트', r'검증',
        r'feasib', r'can\s+we', r'possible', r'prototype',
        r'validate', r'proof\s+of\s+concept', r'시도',
    ],
    "exploration": [
        r'최신\s*연구', r'논문', r'트렌드', r'탐색', r'이론',
        r'survey', r'state[\s-]*of[\s-]*the[\s-]*art', r'sota',
        r'research\s+trend', r'emerging', r'frontier', r'방향',
    ],
    "compliance": [
        r'규정', r'법률', r'컴플라이언스', r'compliance', r'regulation',
        r'audit', r'감사', r'보안', r'security', r'gdpr', r'iso',
        r'정책', r'policy', r'legal', r'법적', r'인증', r'certif',
    ],
    "comparative": [
        r'비교', r'compare', r'vs\b', r'versus', r'차이',
        r'어떤.*좋', r'어떤.*선택', r'which\s+is\s+better',
        r'alternative', r'대안', r'장단점', r'pros\s+and\s+cons',
        r'trade[\s-]*off', r'선택.*기준',
    ],
    "default": [
        r'구현', r'적용', r'방법', r'도구', r'솔루션',
        r'추천', r'선택',
        r'how\s+to', r'best\s+practice', r'implement',
        r'production', r'deploy', r'setup', r'configure',
    ],
}
COMPILED = {k: [re.compile(p) for p in v] for k, v in PROFILE_PATTERNS.items()}

def match_count(compiled, text):
    return sum(1 for p in compiled if p.search(text))

query = sys.argv[1].lower()
all_scores = {k: match_count(v, query) for k, v in COMPILED.items()}
max_score = max(all_scores.values())

# Priority order: compliance > comparative > poc > exploration > default
priority = ["compliance", "comparative", "poc", "exploration", "default"]
profile = "default"
for p in priority:
    if all_scores[p] == max_score and all_scores[p] > 0:
        profile = p
        break

print(json.dumps({
    "profile": profile,
    "scores": all_scores,
    "confidence": "high" if max_score >= 2 else "medium" if max_score >= 1 else "low"
}))
PYEOF
}

cmd_complexity() {
    local query="$1"
    python3 - "$query" << 'PYEOF'
import json, sys, re

query = sys.argv[1].lower()

# Complexity heuristics
word_count = len(query.split())
has_comparison = bool(re.search(r'(vs|versus|비교|compare|차이|difference)', query))
has_multiple_topics = len(re.findall(r'(and|와|과|및|\+|,)', query)) >= 2
has_deep_words = bool(re.search(r'(심층|종합|전체|포괄|comprehensive|thorough|deep|detailed)', query))

if word_count > 20 or (has_comparison and has_multiple_topics) or has_deep_words:
    complexity = 3
    workers = {"min": 5, "max": 8}
    calls_per_worker = {"min": 15, "max": 20}
elif word_count > 10 or has_comparison or has_multiple_topics:
    complexity = 2
    workers = {"min": 3, "max": 4}
    calls_per_worker = {"min": 10, "max": 15}
else:
    complexity = 1
    workers = {"min": 1, "max": 2}
    calls_per_worker = {"min": 3, "max": 10}

print(json.dumps({
    "complexity": complexity,
    "workers": workers,
    "calls_per_worker": calls_per_worker,
    "signals": {
        "word_count": word_count,
        "has_comparison": has_comparison,
        "has_multiple_topics": has_multiple_topics,
        "has_deep_words": has_deep_words
    }
}))
PYEOF
}

cmd_recency() {
    local query="$1" depth="${2:-standard}"
    python3 - "$query" "$depth" << 'PYEOF'
import json, sys

query, depth = sys.argv[1].lower(), sys.argv[2]

depth_map = {"surface": "1y", "standard": "2y", "deep": "5y"}
recency = depth_map.get(depth, "2y")

# Override if query mentions specific timeframes
import re
if re.search(r'(최신|latest|recent|2026|이번\s*달|올해)', query):
    recency = "1y"
elif re.search(r'(역사|history|evolution|변천|since\s+\d{4})', query):
    recency = "5y"

print(json.dumps({"recency": recency, "depth": depth}))
PYEOF
}

cmd_all() {
    local query="$1" depth="${2:-standard}"
    python3 - "$query" "$depth" << 'PYEOF'
import json, sys, re

# Profile patterns — same 5 buckets as cmd_profile, compiled once
PROFILE_PATTERNS = {
    "compliance": [r'규정', r'법률', r'컴플라이언스', r'compliance', r'regulation', r'gdpr', r'iso\s*\d', r'audit', r'감사', r'정책', r'policy'],
    "comparative": [r'비교', r'compare', r'vs\b', r'versus', r'차이', r'difference', r'대안', r'alternative'],
    "poc": [r'가능한가', r'될까', r'poc', r'테스트', r'검증', r'feasib', r'prototype'],
    "exploration": [r'최신\s*연구', r'논문', r'트렌드', r'탐색', r'이론', r'survey', r'sota', r'research\s+trend'],
    "default": [r'구현', r'적용', r'방법', r'도구', r'솔루션', r'어떤.*좋', r'how\s+to', r'implement', r'production'],
}
COMPILED = {k: [re.compile(p) for p in v] for k, v in PROFILE_PATTERNS.items()}

# Complexity / recency aux patterns — also compiled once
RE_CMP = re.compile(r'(vs|versus|비교|compare)')
RE_MULTI = re.compile(r'(and|와|과|및|\+|,)')
RE_DEEP = re.compile(r'(심층|종합|comprehensive|thorough|deep)')
RE_RECENT = re.compile(r'(최신|latest|recent|2026)')
RE_HISTORY = re.compile(r'(역사|history|evolution)')

query, depth = sys.argv[1], sys.argv[2]
ql = query.lower()

# --- Profile ---
def mc(compiled, t):
    return sum(1 for p in compiled if p.search(t))

scores = {k: mc(v, ql) for k, v in COMPILED.items()}
max_score = max(scores.values())
priority = ["compliance", "comparative", "poc", "exploration", "default"]
profile = "default"
for p in priority:
    if scores[p] == max_score and scores[p] > 0:
        profile = p
        break

# --- Complexity ---
wc = len(query.split())
has_cmp = bool(RE_CMP.search(ql))
has_multi = len(RE_MULTI.findall(ql)) >= 2
has_deep = bool(RE_DEEP.search(ql))
if wc > 20 or (has_cmp and has_multi) or has_deep:
    cx, wk = 3, {"min": 5, "max": 8}
elif wc > 10 or has_cmp or has_multi:
    cx, wk = 2, {"min": 3, "max": 4}
else:
    cx, wk = 1, {"min": 1, "max": 2}

# --- Recency ---
dm = {"surface": "1y", "standard": "2y", "deep": "5y"}
rec = dm.get(depth, "2y")
if RE_RECENT.search(ql):
    rec = "1y"
elif RE_HISTORY.search(ql):
    rec = "5y"

print(json.dumps({
    "profile": profile,
    "complexity": cx,
    "workers": wk,
    "recency": rec,
    "depth": depth,
}, ensure_ascii=False))
PYEOF
}

case "${1:-help}" in
    profile)    cmd_profile "$2" ;;
    complexity) cmd_complexity "$2" ;;
    recency)    cmd_recency "$2" "${3:-standard}" ;;
    all)        cmd_all "$2" "${3:-standard}" ;;
    help)       usage ;;
    *)          usage ;;
esac

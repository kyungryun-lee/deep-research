#!/usr/bin/env bash
# Deep Research Dedup CLI
# Removes duplicate sources from worker findings
# Input: Worker findings text (stdin) or JSON array of sources
# Output: Deduplicated results + duplicate report

set -euo pipefail

usage() {
    cat <<'EOF'
Deep Research Dedup CLI

Usage: dr-dedup [command]

Commands:
  urls     Deduplicate URL list (stdin: JSON array of URLs)
  text     Deduplicate sources in worker findings text (stdin: findings text)
  help     Show this help

Examples:
  echo '["https://arxiv.org/abs/2401.00001","https://www.arxiv.org/abs/2401.00001"]' | dr-dedup urls
  cat findings.txt | dr-dedup text
EOF
}

cmd_urls() {
    local tmpfile libdir
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    libdir="$(cd "$(dirname "$0")/lib" && pwd)"

    python3 - "$libdir" "$tmpfile" << 'PYEOF'
import json, sys
sys.path.insert(0, sys.argv[1])
from dr_text import normalize_url

with open(sys.argv[2]) as f:
    urls = json.loads(f.read())

seen = {}
unique = []
duplicates = []

for url in urls:
    norm = normalize_url(url)
    if norm in seen:
        duplicates.append({"url": url, "duplicate_of": seen[norm]})
    else:
        seen[norm] = url
        unique.append(url)

print(json.dumps({
    "unique": unique,
    "duplicates": duplicates,
    "stats": {
        "input": len(urls),
        "unique": len(unique),
        "removed": len(duplicates)
    }
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_text() {
    local tmpfile libdir
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    libdir="$(cd "$(dirname "$0")/lib" && pwd)"

    python3 - "$libdir" "$tmpfile" << 'PYEOF'
import re, sys, json
sys.path.insert(0, sys.argv[1])
from dr_text import normalize_url

with open(sys.argv[2]) as f:
    text = f.read()

# Extract all URLs from text
url_pattern = r'https?://[^\s\)\]>\"\'`]+'
urls = re.findall(url_pattern, text)

seen = {}
duplicates = []
for url in urls:
    norm = normalize_url(url)
    if norm in seen:
        duplicates.append({"url": url, "first_seen": seen[norm]})
    else:
        seen[norm] = url

# Report
if duplicates:
    print(json.dumps({
        "has_duplicates": True,
        "total_urls": len(urls),
        "unique_urls": len(seen),
        "duplicates": duplicates,
        "warning": f"{len(duplicates)} duplicate URL(s) found in findings"
    }, ensure_ascii=False, indent=2))
else:
    print(json.dumps({
        "has_duplicates": False,
        "total_urls": len(urls),
        "unique_urls": len(seen),
        "duplicates": []
    }, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

case "${1:-help}" in
    urls)  cmd_urls ;;
    text)  cmd_text ;;
    help)  usage ;;
    *)     usage ;;
esac

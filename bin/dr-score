#!/usr/bin/env bash
# Deep Research Score Calculator
# Deterministic score calculation — replaces AI arithmetic
# Input: JSON with dimension scores + rubric weights
# Output: total score, SEA rate, PASS/FAIL verdict

set -euo pipefail

usage() {
    cat <<'EOF'
Deep Research Score Calculator

Usage: dr-score <command> [args]

Commands:
  calc --rubric <path> [--code-metrics <json>]  Calculate weighted total (stdin: dimension scores JSON)
  sea                     Calculate SEA sufficiency rate (stdin JSON)
  plateau                 Detect score plateau from history (stdin JSON array)
  diversity               Source diversity Shannon entropy (stdin: URL JSON array)
  recency                 Date-weighted recency score (stdin: [{"url":"...","year":2026},...])
  xref                    Cross-reference density (stdin: claim-evidence JSON)
  structure               Markdown structure analysis (stdin: markdown text)
  help                    Show this help

Input format (calc):
  {"scores":{"accuracy":85,"coverage":70,...},"target_score":80}

Input format (sea):
  {"checked":["item1","item2"],"total":["item1","item2","item3"],"threshold":75}

Input format (plateau):
  {"history":[78,80,81],"threshold":3,"consecutive":2}
EOF
}

cmd_calc() {
    local rubric_path="" code_metrics=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --rubric) rubric_path="$2"; shift 2 ;;
            --code-metrics) code_metrics="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"

    python3 - "$tmpfile" "$rubric_path" "$code_metrics" << 'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    input_data = json.loads(f.read())
scores = input_data['scores']
target = input_data.get('target_score', 80)

# Code metrics integration
# Structure & Coverage: 100% code (AI判断不要)
# Recency: 70% code + 30% AI blending
code_metrics_str = sys.argv[3] if len(sys.argv) > 3 else ''
if code_metrics_str:
    try:
        cm = json.loads(code_metrics_str)
        # 100% code dims: structure_coherence/structure, coverage
        code_only_dims = {
            'structure_coherence': 'structure_score',
            'structure': 'structure_score',
        }
        for dim, cm_key in code_only_dims.items():
            if dim in scores and cm_key in cm:
                scores[dim] = round(cm[cm_key], 1)
        # Coverage from SEA rate if available
        if 'sea_rate' in cm:
            for cov_dim in ('coverage',):
                if cov_dim in scores:
                    scores[cov_dim] = round(cm['sea_rate'], 1)
        # 70/30 blend dims: recency only
        blend_dims = {'recency': 'recency_score'}
        for dim, cm_key in blend_dims.items():
            if dim in scores and cm_key in cm:
                ai_val = scores[dim]
                code_val = cm[cm_key]
                scores[dim] = round(0.7 * code_val + 0.3 * ai_val, 1)
    except:
        pass  # Fallback to AI-only scores

# Load rubric weights
weights = None
rubric_path = sys.argv[2] if len(sys.argv) > 2 else ''
if rubric_path:
    try:
        with open(rubric_path) as f:
            content = f.read()
        # Extract JSON block from rubric markdown
        import re
        m = re.search(r'\`\`\`json\s*\n({.*?})\s*\n\`\`\`', content, re.DOTALL)
        if m:
            weights = json.loads(m.group(1))
    except:
        pass

# Default weights (실무 솔루션 프로필)
if not weights:
    weights = {
        "core": {"accuracy": 0.15, "coverage": 0.10, "recency": 0.10, "structure": 0.05},
        "context": {"proven": 0.20, "actionability": 0.20, "efficiency": 0.10, "env_fit": 0.10}
    }

# Flatten weights (skip non-dimension keys)
SKIP_KEYS = {'sea_threshold', 'hard_floor'}
flat_weights = {}
for key, category in weights.items():
    if key in SKIP_KEYS:
        continue
    if isinstance(category, dict):
        for dim, w in category.items():
            if isinstance(w, (int, float)):
                flat_weights[dim] = w

# Calculate weighted total
total = 0.0
breakdown = {}
missing = []
for dim, w in flat_weights.items():
    if dim in scores:
        contribution = scores[dim] * w
        total += contribution
        breakdown[dim] = {"score": scores[dim], "weight": w, "contribution": round(contribution, 2)}
    elif dim not in ('sea_threshold',):
        missing.append(dim)

total = round(total, 1)

# Determine verdict
sea_threshold = None
for category in weights.values():
    if isinstance(category, dict) and 'sea_threshold' in category:
        sea_threshold = category['sea_threshold']
if not sea_threshold:
    sea_threshold = weights.get('sea_threshold', 75)

# Hard floor rule: if accuracy < threshold, cap total score
hard_floor = None
for category in weights.values():
    if isinstance(category, dict) and 'hard_floor' in category:
        hard_floor = category['hard_floor']
if not hard_floor:
    hard_floor = weights.get('hard_floor', None)

hard_floor_applied = False
floor_dim = None
floor_threshold = 0
floor_cap = 50
if hard_floor and isinstance(hard_floor, dict):
    # Explicit pop to avoid key-order dependence:
    # rubric may serialize {"cap": 50, "accuracy": 40} or {"accuracy": 40, "cap": 50}.
    hf = dict(hard_floor)
    floor_cap = hf.pop('cap', 50)
    # Remaining key(s) are dimension thresholds; pick first that maps to a real score
    for k, v in hf.items():
        if k in scores:
            floor_dim = k
            floor_threshold = v
            break
    if floor_dim and scores.get(floor_dim, 0) < floor_threshold:
        total = min(total, floor_cap)
        hard_floor_applied = True

verdict = "PASS" if total >= target else "FAIL"

# Find weakest dimensions
sorted_dims = sorted(breakdown.items(), key=lambda x: x[1]['score'])
fail_dimensions = [d for d, info in sorted_dims if info['score'] < 70]

result = {
    "total": total,
    "target": target,
    "verdict": verdict,
    "breakdown": breakdown,
    "fail_dimensions": fail_dimensions,
    "weakest": sorted_dims[0][0] if sorted_dims else None,
    "missing_dimensions": missing
}
if hard_floor_applied:
    result["hard_floor_applied"] = True
    result["hard_floor_reason"] = f"{floor_dim} ({scores.get(floor_dim, 0)}) < {floor_threshold} → total capped at {floor_cap}"

print(json.dumps(result, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_sea() {
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"

    python3 - "$tmpfile" << 'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    data = json.loads(f.read())
checked = data.get('checked', [])
total = data.get('total', [])
threshold = data.get('threshold', 75)

if not total:
    print(json.dumps({"rate": 0, "sufficient": False, "unchecked": []}))
    sys.exit(0)

rate = round(len(checked) / len(total) * 100, 1)
unchecked = [item for item in total if item not in checked]
sufficient = rate >= threshold

print(json.dumps({
    "rate": rate,
    "threshold": threshold,
    "sufficient": sufficient,
    "checked_count": len(checked),
    "total_count": len(total),
    "unchecked": unchecked
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_plateau() {
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"

    python3 - "$tmpfile" << 'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    data = json.loads(f.read())
history = data.get('history', [])
threshold = data.get('threshold', 3)      # minimum improvement to not be plateau
consecutive = data.get('consecutive', 2)   # consecutive low-improvement rounds

if len(history) < 2:
    print(json.dumps({"plateau": False, "reason": "insufficient history"}))
else:
    improvements = [history[i] - history[i-1] for i in range(1, len(history))]

    # Check last N improvements
    recent = improvements[-consecutive:] if len(improvements) >= consecutive else improvements
    is_plateau = all(imp < threshold for imp in recent) and len(recent) >= consecutive

    # Check if all dimensions >= 70 (near-sufficient)
    near_sufficient = all(s >= 70 for s in [history[-1]]) if history else False

    print(json.dumps({
        "plateau": is_plateau,
        "improvements": improvements,
        "recent_improvements": recent,
        "threshold": threshold,
        "consecutive_required": consecutive,
        "recommendation": "EARLY_STOP" if is_plateau else "CONTINUE",
        "reason": f"Last {len(recent)} improvements all < {threshold}%" if is_plateau else "Still improving"
    }, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_diversity() {
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    python3 - "$tmpfile" << 'PYEOF'
import json, sys, math
from urllib.parse import urlparse

with open(sys.argv[1]) as f:
    urls = json.loads(f.read())
if not urls:
    print(json.dumps({"entropy": 0, "unique_domains": 0, "total": 0}))
    sys.exit(0)

domains = []
for u in urls:
    try:
        netloc = urlparse(u).netloc.replace("www.", "")
        if netloc:
            domains.append(netloc)
    except:
        pass

total = len(domains)
if total == 0:
    print(json.dumps({"entropy": 0, "unique_domains": 0, "total": 0}))
    sys.exit(0)

from collections import Counter
counts = Counter(domains)
unique = len(counts)
entropy = -sum((c/total) * math.log2(c/total) for c in counts.values()) if total > 0 else 0

print(json.dumps({
    "entropy": round(entropy, 3),
    "unique_domains": unique,
    "total": total,
    "top_domains": dict(counts.most_common(5))
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_recency() {
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    python3 - "$tmpfile" << 'PYEOF'
import json, sys
from datetime import datetime

with open(sys.argv[1]) as f:
    sources = json.loads(f.read())
if not sources:
    print(json.dumps({"score": 0, "recent_ratio": 0, "total": 0}))
    sys.exit(0)

current_year = datetime.now().year
scores = []
recent_count = 0

for src in sources:
    year = src.get("year", current_year - 3)
    if isinstance(year, str):
        try: year = int(year[:4])
        except: year = current_year - 3
    age = current_year - year
    score = max(0, 100 - (age * 25))  # 0yr=100, 1yr=75, 2yr=50, 3yr=25, 4yr+=0
    scores.append(score)
    if age <= 2:
        recent_count += 1

total = len(scores)
avg_score = round(sum(scores) / total, 1) if total else 0
recent_ratio = round(recent_count / total, 3) if total else 0

print(json.dumps({
    "score": avg_score,
    "recent_ratio": recent_ratio,
    "recent_count": recent_count,
    "total": total,
    "recency_score": avg_score
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_xref() {
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    python3 - "$tmpfile" << 'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    data = json.loads(f.read())
claims = data if isinstance(data, list) else data.get("claims", [])

if not claims:
    print(json.dumps({"density": 0, "multi_cited": 0, "single_cited": 0, "total": 0}))
    sys.exit(0)

multi = 0
single = 0
no_evidence = 0

for claim in claims:
    ev = claim.get("evidence", [])
    if len(ev) >= 2:
        multi += 1
    elif len(ev) == 1:
        single += 1
    else:
        no_evidence += 1

total = len(claims)
density = round(multi / total, 3) if total else 0

print(json.dumps({
    "density": density,
    "multi_cited": multi,
    "single_cited": single,
    "no_evidence": no_evidence,
    "total": total
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_structure() {
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    python3 - "$tmpfile" << 'PYEOF'
import json, sys, re

with open(sys.argv[1]) as f:
    text = f.read()
if not text.strip():
    print(json.dumps({"score": 0, "headings": {}, "balance": 0, "word_count": 0}))
    sys.exit(0)

h1 = len(re.findall(r'^# ', text, re.MULTILINE))
h2 = len(re.findall(r'^## ', text, re.MULTILINE))
h3 = len(re.findall(r'^### ', text, re.MULTILINE))
word_count = len(text.split())

# Section balance: split by h2, measure length variance
sections = re.split(r'^## ', text, flags=re.MULTILINE)
if len(sections) > 1:
    lengths = [len(s.split()) for s in sections[1:]]  # skip pre-h2 content
    avg_len = sum(lengths) / len(lengths)
    if avg_len > 0:
        variance = sum((l - avg_len)**2 for l in lengths) / len(lengths)
        cv = (variance ** 0.5) / avg_len  # coefficient of variation
        balance = round(max(0, 1 - cv) * 100, 1)  # 100=perfect balance, 0=extreme imbalance
    else:
        balance = 0
else:
    balance = 0

# Structure score: heading hierarchy + balance + word count adequacy
hierarchy_score = min(100, (h1 > 0) * 20 + min(h2, 8) * 8 + min(h3, 15) * 2)
length_score = min(100, word_count / 20)  # 2000 words = 100
score = round(0.4 * hierarchy_score + 0.3 * balance + 0.3 * length_score, 1)

print(json.dumps({
    "score": score,
    "structure_score": score,
    "headings": {"h1": h1, "h2": h2, "h3": h3},
    "balance": balance,
    "word_count": word_count
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

cmd_kpr_kpc() {
    # Key-point Recall (KPR) + Key-point Contradiction (KPC)
    # SOTA metric from Deep-Research Eval (MDPI 2076-3417/16/5/2546)
    # Input: JSON with "key_points" (expected) and "report_claims" (actual)
    local tmpfile
    tmpfile=$(mktemp)
    cat > "$tmpfile"
    python3 - "$tmpfile" << 'PYEOF'
import json, sys, re, math
from collections import Counter

with open(sys.argv[1]) as f:
    data = json.loads(f.read())

key_points = data.get("key_points", [])  # expected key points from SEA/plan
report_claims = data.get("report_claims", [])  # actual claims in report

if not key_points:
    print(json.dumps({"kpr": 1.0, "kpc": 0.0, "note": "no key points provided"}))
    sys.exit(0)

def tokenize(text):
    return set(re.findall(r'[a-z0-9\uac00-\ud7a3]+', text.lower()))

def overlap(a, b):
    ta, tb = tokenize(a), tokenize(b)
    if not ta or not tb:
        return 0.0
    return len(ta & tb) / min(len(ta), len(tb))

# KPR: fraction of key_points that are covered by report_claims
covered = 0
coverage_details = []
for kp in key_points:
    best_match = max((overlap(kp, rc) for rc in report_claims), default=0)
    is_covered = best_match >= 0.3
    if is_covered:
        covered += 1
    coverage_details.append({"key_point": kp[:80], "best_overlap": round(best_match, 3), "covered": is_covered})

kpr = round(covered / len(key_points), 3)

# KPC: fraction of report_claims that contradict key_points
negations = {'not', 'no', 'never', 'without', 'lack', 'fail', 'cannot',
             '없', '아닌', '불가', '못', '실패', '부족'}
contradictions = 0
for rc in report_claims:
    rc_tokens = tokenize(rc)
    rc_has_neg = bool(rc_tokens & negations)
    for kp in key_points:
        kp_tokens = tokenize(kp)
        kp_has_neg = bool(kp_tokens & negations)
        if overlap(rc, kp) >= 0.3 and rc_has_neg != kp_has_neg:
            contradictions += 1
            break

kpc = round(contradictions / len(report_claims), 3) if report_claims else 0.0

# Composite Consistency Index (CCI)
cci = round(kpr * (1 - kpc), 3)

print(json.dumps({
    "kpr": kpr,
    "kpc": kpc,
    "cci": cci,
    "key_points_total": len(key_points),
    "key_points_covered": covered,
    "report_claims_total": len(report_claims),
    "contradictions": contradictions,
    "coverage_details": coverage_details[:10]
}, ensure_ascii=False, indent=2))
PYEOF
    rm -f "$tmpfile"
}

case "${1:-help}" in
    calc)       shift; cmd_calc "$@" ;;
    sea)        cmd_sea ;;
    plateau)    cmd_plateau ;;
    diversity)  cmd_diversity ;;
    recency)    cmd_recency ;;
    xref)       cmd_xref ;;
    structure)  cmd_structure ;;
    kpr-kpc)    cmd_kpr_kpc ;;
    help)       usage ;;
    *)          usage ;;
esac

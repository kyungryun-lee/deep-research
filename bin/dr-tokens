#!/usr/bin/env bash
# Deep Research Token Usage Dashboard
# Tracks and reports token usage per phase for complexity analysis
# Reads from execution logs and provides per-session analytics

set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DATA_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/deep-research}"
TOKEN_DIR="$DATA_DIR/tokens"

usage() {
    cat <<'EOF'
Deep Research Token Dashboard

Usage: dr-tokens <command> [args]

Commands:
  record --phase <name> --input <n> --output <n> [--model <m>] [--session <id>]
                              Record token usage for a phase
  report [--session <id>]     Show token usage report (default: latest session)
  history [--last <n>]        Show usage history across sessions (default: 10)
  estimate --query "query" --depth <d>
                              Estimate token usage before running research
  compare --s1 <id> --s2 <id> Compare token usage between sessions
  help                        Show this help

Note: This dashboard tracks token counts for complexity analysis.
      Max plan users are not billed per-token.
EOF
}

cmd_record() {
    local phase="" input_tokens=0 output_tokens=0 model="sonnet" session=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --phase) phase="$2"; shift 2 ;;
            --input) input_tokens="$2"; shift 2 ;;
            --output) output_tokens="$2"; shift 2 ;;
            --model) model="$2"; shift 2 ;;
            --session) session="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$phase" ]] && { echo '{"error":"--phase required"}'; return 1; }
    [[ -z "$session" ]] && session=$(date +%Y%m%d-%H%M)

    mkdir -p "$TOKEN_DIR" 2>/dev/null

    python3 - "$phase" "$input_tokens" "$output_tokens" "$model" "$session" "$TOKEN_DIR/usage.jsonl" << 'PYEOF'
import json, sys
from datetime import datetime

phase, input_t_s, output_t_s, model, session, log_path = sys.argv[1:7]
input_t = int(input_t_s)
output_t = int(output_t_s)

entry = {
    "timestamp": datetime.now().isoformat(),
    "session": session,
    "phase": phase,
    "model": model,
    "input_tokens": input_t,
    "output_tokens": output_t,
    "total_tokens": input_t + output_t
}

with open(log_path, "a") as f:
    f.write(json.dumps(entry, ensure_ascii=False) + "\n")

print(json.dumps(entry, ensure_ascii=False, indent=2))
PYEOF
}

cmd_report() {
    local session=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --session) session="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    python3 - "$TOKEN_DIR/usage.jsonl" "$session" << 'PYEOF'
import json, sys, os

log_path, target_session = sys.argv[1], sys.argv[2]

if not os.path.exists(log_path):
    print(json.dumps({"error": "No usage data yet. Use 'dr-tokens record' to start tracking."}))
    sys.exit(0)

# Streaming aggregation — never hold full entry list in memory.
# Group per-session into compact dicts; pick target session at the end.
all_sessions = {}  # session_id -> {"phases": {...}, "models": {...}, "total_input", "total_output"}

with open(log_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        e = json.loads(line)
        sid = e["session"]
        s = all_sessions.setdefault(sid, {
            "phases": {},
            "models": {},
            "total_input": 0,
            "total_output": 0,
        })
        p = e["phase"]
        ph = s["phases"].setdefault(p, {"input": 0, "output": 0, "calls": 0, "models": set()})
        ph["input"] += e["input_tokens"]
        ph["output"] += e["output_tokens"]
        ph["calls"] += 1
        ph["models"].add(e["model"])

        m = e["model"]
        mm = s["models"].setdefault(m, {"input": 0, "output": 0, "calls": 0})
        mm["input"] += e["input_tokens"]
        mm["output"] += e["output_tokens"]
        mm["calls"] += 1

        s["total_input"] += e["input_tokens"]
        s["total_output"] += e["output_tokens"]

if not all_sessions:
    print(json.dumps({"error": "No usage data found"}))
    sys.exit(0)

# Pick target session (default: latest by sorted id)
sessions_sorted = sorted(all_sessions.keys())
if not target_session:
    target_session = sessions_sorted[-1]

if target_session not in all_sessions:
    print(json.dumps({"error": f"Session '{target_session}' not found", "available": sessions_sorted}))
    sys.exit(0)

session = all_sessions[target_session]
phases = session["phases"]
models = session["models"]
total_input = session["total_input"]
total_output = session["total_output"]
total_tokens = total_input + total_output

report = {
    "session": target_session,
    "total": {
        "input_tokens": total_input,
        "output_tokens": total_output,
        "total_tokens": total_tokens
    },
    "by_phase": {
        p: {
            "input_tokens": d["input"],
            "output_tokens": d["output"],
            "total_tokens": d["input"] + d["output"],
            "calls": d["calls"],
            "models": sorted(d["models"]),
            "pct_of_total": round((d["input"] + d["output"]) / total_tokens * 100, 1) if total_tokens > 0 else 0
        }
        for p, d in sorted(phases.items(), key=lambda x: -(x[1]["input"] + x[1]["output"]))
    },
    "by_model": {
        m: {
            "input_tokens": d["input"],
            "output_tokens": d["output"],
            "total_tokens": d["input"] + d["output"],
            "calls": d["calls"],
            "pct_of_total": round((d["input"] + d["output"]) / total_tokens * 100, 1) if total_tokens > 0 else 0
        }
        for m, d in sorted(models.items(), key=lambda x: -(x[1]["input"] + x[1]["output"]))
    },
    "optimization_hints": []
}

# Generate optimization hints (token-based, not cost-based)
most_token_phase = max(phases.items(), key=lambda x: x[1]["input"] + x[1]["output"])
phase_tokens = most_token_phase[1]["input"] + most_token_phase[1]["output"]
if phase_tokens > total_tokens * 0.4:
    report["optimization_hints"].append(
        f"{most_token_phase[0]} uses {round(phase_tokens/total_tokens*100)}% of tokens — consider model downgrade or output length reduction"
    )

for p, d in phases.items():
    if d["output"] > d["input"] * 3:
        report["optimization_hints"].append(
            f"{p}: output/input ratio is {d['output']/d['input']:.1f}x — consider constraining output length"
        )

print(json.dumps(report, ensure_ascii=False, indent=2))
PYEOF
}

cmd_history() {
    local last=10
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --last) last="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    python3 - "$TOKEN_DIR/usage.jsonl" "$last" << 'PYEOF'
import json, sys, os

log_path, limit = sys.argv[1], int(sys.argv[2])

if not os.path.exists(log_path):
    print(json.dumps({"sessions": [], "message": "No usage history yet"}))
    sys.exit(0)

# Streaming aggregation by session id (no full-file load)
sessions = {}
with open(log_path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        e = json.loads(line)
        s = e["session"]
        d = sessions.setdefault(s, {"input": 0, "output": 0, "phases": 0, "models": set()})
        d["input"] += e["input_tokens"]
        d["output"] += e["output_tokens"]
        d["phases"] += 1
        d["models"].add(e["model"])

result = []
for sid in sorted(sessions.keys(), reverse=True)[:limit]:
    d = sessions[sid]
    result.append({
        "session": sid,
        "total_tokens": d["input"] + d["output"],
        "phases": d["phases"],
        "models": sorted(d["models"])
    })

print(json.dumps({"sessions": result, "total_sessions": len(sessions)}, ensure_ascii=False, indent=2))
PYEOF
}

cmd_estimate() {
    local query="" depth="standard"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --query) query="$2"; shift 2 ;;
            --depth) depth="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    python3 - "$depth" << 'PYEOF'
import json, sys

DEPTH_MULTIPLIER = {"surface": 0.5, "standard": 1.0, "deep": 2.0}
depth = sys.argv[1]
mult = DEPTH_MULTIPLIER.get(depth, 1.0)

# Estimated tokens per phase (based on typical research runs)
phases = {
    "planner":     {"model": "sonnet", "input": int(5000 * mult),  "output": int(2000 * mult)},
    "workers":     {"model": "sonnet", "input": int(30000 * mult), "output": int(15000 * mult)},
    "evaluator":   {"model": "opus",   "input": int(20000 * mult), "output": int(5000 * mult)},
    "synthesizer": {"model": "opus",   "input": int(25000 * mult), "output": int(10000 * mult)},
    "supplement":  {"model": "sonnet", "input": int(10000 * mult), "output": int(5000 * mult)},
}

total_tokens = 0
breakdown = {}
for phase, info in phases.items():
    phase_total = info["input"] + info["output"]
    total_tokens += phase_total
    breakdown[phase] = {
        "model": info["model"],
        "est_input": info["input"],
        "est_output": info["output"],
        "est_total": phase_total
    }

print(json.dumps({
    "depth": depth,
    "estimated_total_tokens": total_tokens,
    "breakdown": breakdown,
    "note": "Estimates based on typical research runs. Max plan: no per-token billing."
}, ensure_ascii=False, indent=2))
PYEOF
}

cmd_compare() {
    local s1="" s2=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --s1) s1="$2"; shift 2 ;;
            --s2) s2="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    [[ -z "$s1" || -z "$s2" ]] && { echo '{"error":"--s1 and --s2 required"}'; return 1; }

    python3 - "$TOKEN_DIR/usage.jsonl" "$s1" "$s2" << 'PYEOF'
import json, sys, os

log_path, s1, s2 = sys.argv[1], sys.argv[2], sys.argv[3]

if not os.path.exists(log_path):
    print(json.dumps({"error": "No usage data"}))
    sys.exit(0)

entries = []
with open(log_path) as f:
    for line in f:
        if line.strip():
            entries.append(json.loads(line.strip()))

def session_summary(entries, sid):
    se = [e for e in entries if e["session"] == sid]
    if not se:
        return None
    return {
        "session": sid,
        "total_tokens": sum(e["input_tokens"] + e["output_tokens"] for e in se),
        "phases": len(se),
        "input_tokens": sum(e["input_tokens"] for e in se),
        "output_tokens": sum(e["output_tokens"] for e in se),
    }

sum1 = session_summary(entries, s1)
sum2 = session_summary(entries, s2)

if not sum1 or not sum2:
    print(json.dumps({"error": "One or both sessions not found"}))
    sys.exit(0)

diff = {
    "tokens_delta": sum2["total_tokens"] - sum1["total_tokens"],
    "tokens_change_pct": round((sum2["total_tokens"] - sum1["total_tokens"]) / sum1["total_tokens"] * 100, 1) if sum1["total_tokens"] > 0 else 0
}

print(json.dumps({"session_1": sum1, "session_2": sum2, "delta": diff}, ensure_ascii=False, indent=2))
PYEOF
}

case "${1:-help}" in
    record)   shift; cmd_record "$@" ;;
    report)   shift; cmd_report "$@" ;;
    history)  shift; cmd_history "$@" ;;
    estimate) shift; cmd_estimate "$@" ;;
    compare)  shift; cmd_compare "$@" ;;
    help)     usage ;;
    *)        usage ;;
esac
